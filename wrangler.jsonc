{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "skill-router-mcp",
  "main": "src/index.js",
  "workers_dev": true,
  "compatibility_date": "2026-07-21",
  "compatibility_flags": ["nodejs_compat"],
  "assets": {
    "directory": "./public/",
    "binding": "ASSETS",
    "run_worker_first": true
  }
}
